{
  "name": "@accelerated-software-development/playwright-video-merge",
  "version": "0.1.0",
  "description": "Merge Playwright test result videos into a single demo reel with test name overlays",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "bin": {
    "playwright-video-merge": "dist/cli.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "playwright",
    "video",
    "merge",
    "concat",
    "ffmpeg",
    "demo",
    "e2e",
    "test",
    "recording"
  ],
  "author": "contact@kelvin.id",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/asd-engineering/playwright-video-merge.git"
  },
  "bugs": {
    "url": "https://github.com/asd-engineering/playwright-video-merge/issues"
  },
  "homepage": "https://github.com/asd-engineering/playwright-video-merge#readme",
  "dependencies": {
    "commander": "^13.1.0",
    "fluent-ffmpeg": "^2.1.3"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^22.18.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.1"
  }
}
